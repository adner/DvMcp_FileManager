<?xml version="1.0" encoding="utf-8"?>
<!--
  Sparse package manifest. Grants Windows "package identity" to the otherwise-unpackaged
  Explorer host exe so cfapi / StorageProviderSyncRootManager.Register are allowed to run.

  Sparse-package specifics:
    * Properties/uap10:AllowExternalContent = true  -> package may reference the exe that lives
      OUTSIDE the package, at the external location supplied to Add-AppxPackage -ExternalLocation.
    * Application/uap10:RuntimeBehavior = packagedClassicApp + TrustLevel = mediumIL
      -> a classic full-trust win32 exe carried by the package.
    * Identity/Publisher MUST match the signing cert subject exactly (CN=DataverseFileManager.Dev).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap10 rescap">

  <Identity Name="DataverseFileManager"
            Publisher="CN=DataverseFileManager.Dev"
            Version="1.0.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Dataverse File Manager</DisplayName>
    <PublisherDisplayName>Dataverse File Manager (Dev)</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <uap10:AllowExternalContent>true</uap10:AllowExternalContent>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26200.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="DataverseFileManager"
                 Executable="DataverseFileManager.Explorer.exe"
                 EntryPoint="Windows.FullTrustApplication"
                 uap10:RuntimeBehavior="packagedClassicApp"
                 uap10:TrustLevel="mediumIL">
      <uap:VisualElements
        DisplayName="Dataverse File Manager"
        Description="Dataverse-backed files in File Explorer"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
